# Ignore object files and dependency files in obj directory
/obj/
/obj/*.o
/obj/*.d

# Ignore compiled binaries in bin directory
/bin/
/bin/*

# Ignore temporary files and editor backups
*.swp
*.swo
*~
*.bak

# Ignore build artifacts that might be generated by IDEs
*.log
*.tmp

# Ignore OS-specific files
.DS_Store
Thumbs.db
