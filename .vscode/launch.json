{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "C++ Debug",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/bin/ConsoleApp",
            "args": [
                "10",
                "20",
                "14",
                "1",
                "data/siftsmall/siftsmall_base.fvecs",
                "data/siftsmall/siftsmall_query.fvecs",
                "data/siftsmall/siftsmall_groundtruth.fvecs"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "build",
            "miDebuggerPath": "/usr/bin/gdb",
            "logging": {
                "engineLogging": true,
                "traceResponse": true
            }
        }
    ]
}